FROM rockylinux:8
LABEL org.opencontainers.image.authors="j.knedlik@gsi.de"
WORKDIR /tmp
RUN yum install -y git make gcc rpm-build
RUN curl -LO https://go.dev/dl/go1.26.1.linux-amd64.tar.gz
RUN tar -C /usr/local -xvzf go1.26.1.linux-amd64.tar.gz
ENV PATH=$PATH:/usr/local/go/bin
RUN mkdir /go
COPY . /go/lustre_exporter
WORKDIR /go/lustre_exporter
RUN rpm/build.sh
RUN mkdir /rpm
ENTRYPOINT ["cp"]
CMD ["-r","/root/rpmbuild/RPMS/x86_64/","/rpm/build"]
